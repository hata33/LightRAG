# ═══════════════════════════════════════════════════════════════
# LightRAG Demo 配置: PG + Neo4j（Docker）+ 内网 API 模型
# ═══════════════════════════════════════════════════════════════
# 用法: cp .env.demo .env
#
# 数据库在 Docker 容器里（compose 启动），前后端本地手动启动。
# 模型服务（LLM/Embedding/Rerank）在 192.168.1.161 内网部署。
# ═══════════════════════════════════════════════════════════════

# ─── 服务 ───
HOST=0.0.0.0
PORT=9621
WORKING_DIR=./rag_storage
WORKSPACE=demo

# ─── 存储绑定（核心: PG 四合一 + Neo4j 图） ───
LIGHTRAG_KV_STORAGE=PGKVStorage
LIGHTRAG_VECTOR_STORAGE=PGVectorStorage
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage

# ─── PostgreSQL 连接（Docker 暴露到 localhost:5432） ───
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag123
POSTGRES_DATABASE=rag

# pgvector 索引配置
POSTGRES_VECTOR_INDEX_TYPE=HNSW
POSTGRES_HNSW_M=16
POSTGRES_HNSW_EF=200

# ─── Neo4j 连接（Docker 暴露到 localhost:7687） ───
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j123
NEO4J_DATABASE=neo4j

# ─── LLM（内网 OpenAI 兼容 API） ───
LLM_BINDING=openai
LLM_BINDING_HOST=http://192.168.1.161:10001/v1
LLM_BINDING_API_KEY='SII#gemr#2026!!'
LLM_MODEL=LLM

# ─── Embedding（内网 OpenAI 兼容 API） ───
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=http://192.168.1.161:10004/v1
EMBEDDING_BINDING_API_KEY='SII#gemr#2026!!'
EMBEDDING_MODEL=EMBEDDING
EMBEDDING_DIM=1024
EMBEDDING_TOKEN_LIMIT=8192
EMBEDDING_SEND_DIM=false
EMBEDDING_USE_BASE64=true
EMBEDDING_BATCH_NUM=32

# ─── Rerank（内网 Cohere 兼容 API） ───
RERANK_BINDING=cohere
RERANK_BINDING_HOST=http://192.168.1.161:10005/v1/rerank
RERANK_BINDING_API_KEY='SII#gemr#2026!!'
RERANK_MODEL=RERANKER

# ─── 摄入管线调优 ───
MAX_PARALLEL_INSERT=3
CHUNK_SIZE=1200
MAX_GLEANING=1

# ─── 检索参数 ───
TOP_K=60
CHUNK_TOP_K=12

# ─── 认证（Demo 默认关闭，生产请开启） ───
# AUTH_ACCOUNTS=admin:admin123
# TOKEN_SECRET=change-this-to-a-random-secret

# ─── LLM 缓存（省成本，推荐开） ───
ENABLE_LLM_CACHE_FOR_EXTRACT=true
ENABLE_LLM_CACHE_FOR_QUERY=true
